NODE_ENV=development
PORT=3000
LOG_LEVEL=dev

# SQLite — file is created automatically (parent folder too). Path relative to project root or absolute.
SQLITE_DATABASE=data/app.sqlite

# DB_SYNCHRONIZE=true  # optional: enable TypeORM sync in production (SQLite without migrations)

# Redis (optional — leave empty to disable list caching)
REDIS_URL=redis://localhost:6379
