NODE_ENV=development
PORT=3000
LOG_LEVEL=dev

# SQLite — file is created automatically (parent folder too). Path relative to project root or absolute.
SQLITE_DATABASE=data/app.sqlite

# Set true on Railway (production) if you use SQLite without migrations (creates tables on startup)
# DB_SYNCHRONIZE=false

# Redis (optional — leave empty to disable list caching)
REDIS_URL=redis://localhost:6379
